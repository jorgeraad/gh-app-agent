#!/bin/bash
# git-credential-github-app — git credential helper that supplies a fresh
# GitHub App installation token for github.com.
#
# Wire it up in ~/.gitconfig, scoped to the URL prefix you want to route
# through the App (so work-org repos keep using your normal auth):
#
#   [credential "https://github.com/<your-handle>"]
#       helper =
#       helper = /Users/<you>/.github-agent/bin/git-credential-github-app
#       useHttpPath = true
#
# Git invokes us with one of: get, store, erase.
# - get: read key=value lines on stdin until blank, then write back username/password.
# - store/erase: silent no-op (we don't persist git's view of credentials).

set -u
action="${1:-}"
[ "$action" = "get" ] || exit 0

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

host=""
protocol=""
while IFS='=' read -r key value; do
  [ -z "$key" ] && break
  case "$key" in
    host) host="$value" ;;
    protocol) protocol="$value" ;;
  esac
done

# Only respond for github.com over https.
if [ "$host" != "github.com" ] || [ "$protocol" != "https" ]; then
  exit 0
fi

token="$("$SCRIPT_DIR/mint-token.py" 2>/dev/null)" || exit 0
[ -z "$token" ] && exit 0

printf 'username=x-access-token\n'
printf 'password=%s\n' "$token"
